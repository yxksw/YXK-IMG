# Telegram 存储配置
# Telegram Bot Token，从 @BotFather 获取
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID，可以是用户ID或频道ID（格式如: -100xxxxxxxxxx）
TELEGRAM_CHAT_ID=your_chat_id_here

# Telegram API 代理地址（可选）
# 支持以下几种配置方式：
# 1. 使用图床自己的域名作为代理（推荐）:
#    TELEGRAM_PROXY_URL=zycs-img.yxksw.workers.dev/tg-proxy
#    注意：需要在 Workers 部署后才能使用
#
# 2. 使用其他反向代理域名:
#    TELEGRAM_PROXY_URL=api.telegram.org
#
# 3. 不设置（直接访问官方 API）:
#    TELEGRAM_PROXY_URL=
TELEGRAM_PROXY_URL=zycs-img.yxksw.workers.dev/tg-proxy
